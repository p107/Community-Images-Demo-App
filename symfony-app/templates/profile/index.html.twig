{% extends 'base.html.twig' %}

{% block title %}Profile - {{ user.username }}{% endblock %}

{% block styles %}
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .profile-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid #f0f0f0;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
            font-weight: bold;
            margin: 0 auto 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        
        .profile-username {
            font-size: 2em;
            color: #333;
            margin-bottom: 5px;
        }
        
        .profile-handle {
            font-size: 1.2em;
            color: #999;
        }
        
        .profile-details {
            display: grid;
            gap: 25px;
        }
        
        .profile-field {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }
        
        .profile-field-label {
            font-size: 0.85em;
            color: #667eea;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-field-value {
            font-size: 1.1em;
            color: #333;
            word-wrap: break-word;
        }
        
        .profile-field-empty {
            color: #999;
            font-style: italic;
        }
        
        .profile-bio {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #764ba2;
            margin-top: 10px;
        }
        
        .profile-bio-label {
            font-size: 0.85em;
            color: #764ba2;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-bio-text {
            font-size: 1.1em;
            color: #555;
            line-height: 1.6;
        }
        
        .phoenix-section {
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }

        .phoenix-section h2 {
            font-size: 1.2em;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .token-form {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .token-input-group {
            flex: 1;
            min-width: 200px;
        }

        .token-input-group label {
            display: block;
            font-size: 0.85em;
            color: #667eea;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .token-input-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1em;
            transition: border-color 0.2s ease;
            outline: none;
        }

        .token-input-group input:focus {
            border-color: #667eea;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 25px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-import {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(245, 87, 108, 0.3);
        }

        .btn-import:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245, 87, 108, 0.4);
        }


        .profile-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 0.9em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ user.username|slice(0, 1)|upper }}
            </div>
            <h1 class="profile-username">
                {% if user.name %}
                    {{ user.name }} {{ user.lastName|default('') }}
                {% else %}
                    {{ user.username }}
                {% endif %}
            </h1>
            <div class="profile-handle">@{{ user.username }}</div>
        </div>
        
        <div class="profile-details">
            <div class="profile-field">
                <div class="profile-field-label">Email</div>
                <div class="profile-field-value">{{ user.email }}</div>
            </div>
            
            {% if user.age %}
                <div class="profile-field">
                    <div class="profile-field-label">Age</div>
                    <div class="profile-field-value">{{ user.age }} years old</div>
                </div>
            {% endif %}
            
            {% if user.name %}
                <div class="profile-field">
                    <div class="profile-field-label">Full Name</div>
                    <div class="profile-field-value">
                        {{ user.name }}
                        {% if user.lastName %}
                            {{ user.lastName }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
        
        {% if user.bio %}
            <div class="profile-bio">
                <div class="profile-bio-label">About Me</div>
                <div class="profile-bio-text">{{ user.bio }}</div>
            </div>
        {% endif %}
        
        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-number">{{ user.photos|length }}</div>
                <div class="stat-label">Photos</div>
            </div>
        </div>
        
        <div class="phoenix-section">
            <h2>🔗 PhoenixApi — Photo Import</h2>

            <form method="post" action="{{ path('profile_save_token') }}" class="token-form">
                <input type="hidden" name="_token" value="{{ csrf_token('phoenix_token') }}">
                <div class="token-input-group">
                    <label for="phoenix_api_token">Access Token</label>
                    <input
                        type="text"
                        id="phoenix_api_token"
                        name="phoenix_api_token"
                        value="{{ phoenixApiToken ?? '' }}"
                        placeholder="Paste your PhoenixApi access token here"
                        autocomplete="off"
                    >
                </div>
                <button type="submit" class="btn btn-primary">💾 Save Token</button>
            </form>

            {% if phoenixApiToken %}
                <form method="post" action="{{ path('profile_import_photos') }}" style="margin-top: 16px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('import_photos') }}">
                    <button type="submit" class="btn btn-import">📥 Import Photos</button>
                </form>
            {% endif %}
        </div>

        <div style="text-align: center; margin-top: 30px;">
            <a href="{{ path('home') }}" class="btn btn-primary">← Back to Gallery</a>
        </div>
    </div>
{% endblock %}

